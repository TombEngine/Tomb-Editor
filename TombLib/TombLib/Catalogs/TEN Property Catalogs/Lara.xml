<?xml version="1.0" encoding="utf-8"?>
<!--
  TEN Lua Property Catalog - Lara
  
  Custom Lua properties for the LARA moveable object (slot ID 0).
  These properties can be edited globally in WadTool (Level 1) and
  per-instance in TombEditor (Level 2).
  
  See Example.xml for a full reference of supported types and value formats.
-->
<propertyCatalog>
  <moveable id="0">

    <!-- Vitals -->
    <property internalName="maxHealth"
              displayName="Max Health"
              type="Int"
              defaultValue="1000"
              category="Vitals"
              description="Maximum health points Lara can have." />

    <property internalName="maxAir"
              displayName="Max Air"
              type="Int"
              defaultValue="1800"
              category="Vitals"
              description="Maximum air supply in frames (1800 = 60 seconds at 30 FPS)." />

    <property internalName="maxStamina"
              displayName="Max Stamina"
              type="Float"
              defaultValue="120.0"
              category="Vitals"
              description="Maximum sprint stamina in frames." />

    <property internalName="poisonDrainRate"
              displayName="Poison Drain Rate"
              type="Int"
              defaultValue="1"
              category="Vitals"
              description="Health points drained per frame while poisoned." />

    <!-- Movement -->
    <property internalName="walkSpeed"
              displayName="Walk Speed"
              type="Float"
              defaultValue="15.0"
              category="Movement"
              description="Forward velocity when walking." />

    <property internalName="runSpeed"
              displayName="Run Speed"
              type="Float"
              defaultValue="47.0"
              category="Movement"
              description="Forward velocity when running." />

    <property internalName="sprintSpeed"
              displayName="Sprint Speed"
              type="Float"
              defaultValue="60.0"
              category="Movement"
              description="Forward velocity when sprinting." />

    <property internalName="swimSpeed"
              displayName="Swim Speed"
              type="Float"
              defaultValue="50.0"
              category="Movement"
              description="Forward velocity when swimming underwater." />

    <property internalName="jumpHeight"
              displayName="Jump Height"
              type="Float"
              defaultValue="3.0"
              category="Movement"
              description="Vertical jump strength multiplier (1.0 = default engine value)." />

    <property internalName="fallDamageThreshold"
              displayName="Fall Damage Threshold"
              type="Int"
              defaultValue="2560"
              category="Movement"
              description="Fall distance in world units before Lara takes damage." />

    <property internalName="enableCrawl"
              displayName="Enable Crawl"
              type="Bool"
              defaultValue="true"
              category="Movement"
              description="Whether Lara can crouch and crawl." />

    <property internalName="enableMonkeySwing"
              displayName="Enable Monkey Swing"
              type="Bool"
              defaultValue="true"
              category="Movement"
              description="Whether Lara can use monkey swing ceilings." />

    <property internalName="enableSprint"
              displayName="Enable Sprint"
              type="Bool"
              defaultValue="true"
              category="Movement"
              description="Whether Lara can sprint." />

    <!-- Combat -->
    <property internalName="pistolDamage"
              displayName="Pistol Damage"
              type="Int"
              defaultValue="1"
              category="Combat"
              description="Damage dealt per pistol shot." />

    <property internalName="shotgunDamage"
              displayName="Shotgun Damage"
              type="Int"
              defaultValue="3"
              category="Combat"
              description="Damage dealt per shotgun pellet." />

    <property internalName="enableTargetHighlight"
              displayName="Enable Target Highlight"
              type="Bool"
              defaultValue="false"
              category="Combat"
              description="If true, the current auto-aim target is highlighted with an overlay color." />

    <property internalName="targetHighlightColor"
              displayName="Target Highlight Color"
              type="Color"
              defaultValue="255, 0, 0, 128"
              category="Combat"
              description="RGBA color of the target highlight overlay." />

    <!-- Appearance -->
    <property internalName="hairTint"
              displayName="Hair Tint"
              type="Color"
              defaultValue="40, 20, 10"
              category="Appearance"
              description="RGB tint applied to Lara's braid/hair meshes." />

    <property internalName="skinTint"
              displayName="Skin Tint"
              type="Color"
              defaultValue="128, 128, 128"
              category="Appearance"
              description="RGB tint applied to Lara's skin meshes." />

    <property internalName="headlightColor"
              displayName="Headlight Color"
              type="Color"
              defaultValue="192, 192, 160"
              category="Appearance"
              description="RGB color of Lara's dynamic headlight (flare direction light)." />

    <property internalName="headlightRange"
              displayName="Headlight Range"
              type="Float"
              defaultValue="8192.0"
              category="Appearance"
              description="Distance in world units for Lara's headlight illumination." />

    <!-- HUD -->
    <property internalName="showHealthBar"
              displayName="Show Health Bar"
              type="Bool"
              defaultValue="true"
              category="HUD"
              description="Whether the health bar is displayed on screen." />

    <property internalName="showAirBar"
              displayName="Show Air Bar"
              type="Bool"
              defaultValue="true"
              category="HUD"
              description="Whether the air bar is displayed when diving." />

    <property internalName="healthBarPos"
              displayName="Health Bar Position"
              type="Vec2"
              defaultValue="20, 28"
              category="HUD"
              description="Screen position (X, Y) of the health bar in pixels." />

    <property internalName="airBarPos"
              displayName="Air Bar Position"
              type="Vec2"
              defaultValue="20, 48"
              category="HUD"
              description="Screen position (X, Y) of the air bar in pixels." />

    <!-- Behavior -->
    <property internalName="customName"
              displayName="Custom Name"
              type="String"
              defaultValue="Lara"
              category="Behavior"
              description="Display name used in UI text and subtitles." />

    <property internalName="spawnPosition"
              displayName="Spawn Position"
              type="Vec3"
              defaultValue="0, 0, 0"
              category="Behavior"
              description="World position override for Lara's initial spawn. Use (0,0,0) for default placement." />

    <property internalName="spawnRotation"
              displayName="Spawn Rotation"
              type="Rotation"
              defaultValue="0, 0, 0"
              category="Behavior"
              description="Euler angles (pitch, yaw, roll) for Lara's initial facing direction." />

  </moveable>
</propertyCatalog>
