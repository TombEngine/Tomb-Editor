<Window
	x:Class="TombEditor.WPF.Views.ImportedGeometryWindow"
	xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
	xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
	xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
	xmlns:darkCtrl="clr-namespace:DarkUI.WPF.CustomControls;assembly=DarkUI.WPF"
	xmlns:darkUI="clr-namespace:DarkUI.WPF;assembly=DarkUI.WPF"
	xmlns:local="clr-namespace:TombEditor.WPF"
	xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
	
	xmlns:toolwindows="clr-namespace:TombEditor.WPF.ToolWindows"
	xmlns:xceed="http://schemas.xceed.com/wpf/xaml/toolkit"
	Title="{tombLib:Localize ImportedGeometry}"
	Width="700"
	Height="450"
	MinWidth="700"
	MinHeight="450"
	Style="{DynamicResource CustomWindowStyle}"
	mc:Ignorable="d">
	<controls:SpacedGrid Margin="{x:Static darkUI:Defaults.SmallThickness}">
		<controls:SpacedGrid.RowDefinitions>
			<RowDefinition Height="auto" />
			<RowDefinition Height="auto" />
			<RowDefinition />
			<RowDefinition Height="auto" />
			<RowDefinition Height="auto" />
		</controls:SpacedGrid.RowDefinitions>
		<Label Margin="4,0,0,-5" Content="{tombLib:Localize IGDescription1}" />
		<Label
			Grid.Row="1"
			Margin="4,0,0,-5"
			Content="{tombLib:Localize IGDescription2}" />
		<controls:SpacedGrid Grid.Row="2">
			<toolwindows:ImportedGeometryManager />
		</controls:SpacedGrid>
		<GroupBox Grid.Row="3" Header="-">
			<controls:SpacedGrid>
				<controls:SpacedGrid.RowDefinitions>
					<RowDefinition Height="auto" />
					<RowDefinition Height="auto" />
				</controls:SpacedGrid.RowDefinitions>
				<controls:SpacedGrid>
					<Grid.ColumnDefinitions>
						<ColumnDefinition Width="auto" />
						<ColumnDefinition />
						<ColumnDefinition Width="auto" />
					</Grid.ColumnDefinitions>
					<Label Width="80" Content="Chosen entry:" />
					<Label Grid.Column="1" Content="None" />
					<Button
						Grid.Column="2"
						Width="90"
						Content="Assign" />
				</controls:SpacedGrid>
				<controls:SpacedGrid Grid.Row="1">
					<Grid.ColumnDefinitions>
						<ColumnDefinition Width="auto" />
						<ColumnDefinition />
						<ColumnDefinition Width="auto" />
						<ColumnDefinition Width="auto" />
						<ColumnDefinition Width="auto" />
						<ColumnDefinition Width="auto" />
					</Grid.ColumnDefinitions>
					<Label Content="Lighting model:" />
					<ComboBox Grid.Column="1">
						<ComboBoxItem Content="No lights" />
						<ComboBoxItem Content="Vertex colors" />
						<ComboBoxItem Content="Calculate from room lights" />
						<ComboBoxItem Content="Specified tint only" />
					</ComboBox>
					<xceed:ColorPicker
						Name="ClrPcker_Background"
						Grid.Column="2"
						Width="59" />
					<CheckBox Grid.Column="3" Content="Force sharp edges" />
					<CheckBox Grid.Column="4" Content="Faster alpha testing" />
					<CheckBox Grid.Column="5" Content="Hide in editor" />
				</controls:SpacedGrid>
			</controls:SpacedGrid>
		</GroupBox>
		<controls:SpacedGrid Grid.Row="4" HorizontalAlignment="Right">
			<Grid.ColumnDefinitions>
				<ColumnDefinition Width="auto" />
				<ColumnDefinition Width="auto" />
			</Grid.ColumnDefinitions>
			<Button
				Grid.Column="0"
				Width="90"
				Content="{tombLib:Localize OK}"
				IsDefault="True" />
			<Button
				Grid.Column="1"
				Width="90"
				Content="{tombLib:Localize Cancel}"
				DockPanel.Dock="Right" />
		</controls:SpacedGrid>
	</controls:SpacedGrid>
</Window>
