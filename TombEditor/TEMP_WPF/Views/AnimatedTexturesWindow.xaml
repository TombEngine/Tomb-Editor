<Window
	x:Class="TombEditor.WPF.Views.AnimatedTexturesWindow"
	xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
	xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
	xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
	xmlns:darkCtrl="clr-namespace:DarkUI.WPF.CustomControls;assembly=DarkUI.WPF"
	xmlns:darkUI="clr-namespace:DarkUI.WPF;assembly=DarkUI.WPF"
	xmlns:local="clr-namespace:TombEditor.WPF"
	xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
	
	xmlns:xceed="http://schemas.xceed.com/wpf/xaml/toolkit"
	Title="{tombLib:Localize AnimatedTexturesTitle}"
	Width="810"
	Height="630"
	MinWidth="810"
	MinHeight="630"
	Style="{DynamicResource CustomWindowStyle}"
	mc:Ignorable="d">

	<controls:SpacedGrid Margin="{x:Static darkUI:Defaults.SmallThickness}">
		<Grid.ColumnDefinitions>
			<ColumnDefinition Width="60*" />
			<ColumnDefinition Width="40*" />
		</Grid.ColumnDefinitions>
		<controls:SpacedGrid.RowDefinitions>
			<RowDefinition Height="auto" />
			<RowDefinition />
			<RowDefinition Height="auto" />
			<RowDefinition Height="auto" />
		</controls:SpacedGrid.RowDefinitions>
		<controls:SpacedGrid>
			<Grid.ColumnDefinitions>
				<ColumnDefinition Width="Auto" />
				<ColumnDefinition />
				<ColumnDefinition Width="Auto" />
			</Grid.ColumnDefinitions>
			<Label Grid.Column="0" Content="{tombLib:Localize AnimationSet}" />
			<darkCtrl:SearchableComboBox Grid.Column="1" />
			<controls:SpacedGrid Grid.Column="2">
				<Grid.ColumnDefinitions>
					<ColumnDefinition Width="auto" />
					<ColumnDefinition Width="auto" />
					<ColumnDefinition Width="Auto" />
				</Grid.ColumnDefinitions>
				<Button
					Grid.Column="0"
					Style="{DynamicResource ButtonWithIconOnly}"
					ToolTip="{tombLib:Localize EditSetButton}">
					<Image Source="/TombEditor;component/Resources/icons_general/general_edit-16.png" />
				</Button>
				<Button
					Grid.Column="1"
					Style="{DynamicResource ButtonWithIconOnly}"
					ToolTip="{tombLib:Localize AddSetButton}">
					<Image Source="/TombEditor;component/Resources/icons_general/general_plus_math-16.png" />
				</Button>
				<Button
					Grid.Column="2"
					Style="{DynamicResource ButtonWithIconOnly}"
					ToolTip="{tombLib:Localize DeleteSetButton}">
					<Image Source="/TombEditor;component/Resources/icons_general/general_trash-16.png" />
				</Button>
			</controls:SpacedGrid>
		</controls:SpacedGrid>
		<controls:SpacedGrid Grid.Row="1" Grid.Column="0">
			<Grid.ColumnDefinitions>
				<ColumnDefinition />
			</Grid.ColumnDefinitions>
			<GroupBox Header="{tombLib:Localize Frames}">
				<controls:SpacedGrid>
					<Grid.ColumnDefinitions>
						<ColumnDefinition />
						<ColumnDefinition Width="auto" />
					</Grid.ColumnDefinitions>
					<Grid.RowDefinitions>
						<RowDefinition />
					</Grid.RowDefinitions>
					<DataGrid ScrollViewer.VerticalScrollBarVisibility="Visible">
						<DataGrid.Columns>
							<DataGridTemplateColumn Header="{tombLib:Localize Image}">
								<DataGridTemplateColumn.CellTemplate>
									<DataTemplate>
										<Image Name="Image" />
									</DataTemplate>
								</DataGridTemplateColumn.CellTemplate>
							</DataGridTemplateColumn>
							<DataGridTemplateColumn Header="{tombLib:Localize Texture}">
								<DataGridTemplateColumn.CellTemplate>
									<DataTemplate>
										<darkCtrl:SearchableComboBox />
									</DataTemplate>
								</DataGridTemplateColumn.CellTemplate>
							</DataGridTemplateColumn>
							<DataGridTextColumn Header="{tombLib:Localize Repeat}" />
							<DataGridTextColumn Header="{tombLib:Localize Area}" />
							<DataGridTextColumn Header="{tombLib:Localize Edge0}" />
							<DataGridTextColumn Header="{tombLib:Localize Edge1}" />
							<DataGridTextColumn Header="{tombLib:Localize Edge2}" />
							<DataGridTextColumn Header="{tombLib:Localize Edge3}" />
						</DataGrid.Columns>
					</DataGrid>
					<controls:SpacedGrid Grid.Column="1">
						<controls:SpacedGrid.RowDefinitions>
							<RowDefinition Height="auto" />
							<RowDefinition Height="auto" />
							<RowDefinition Height="auto" />
							<RowDefinition Height="*" />
							<RowDefinition Height="auto" />
							<RowDefinition Height="auto" />
						</controls:SpacedGrid.RowDefinitions>
						<Button
							Grid.Row="0"
							Style="{DynamicResource ButtonWithIconOnly}"
							ToolTip="{tombLib:Localize AddFrameButton}">
							<Image Source="/TombEditor;component/Resources/icons_general/general_plus_math-16.png" />
						</Button>
						<Button
							Grid.Row="1"
							Style="{DynamicResource ButtonWithIconOnly}"
							ToolTip="{tombLib:Localize DeleteFrameButton}">
							<Image Source="/TombEditor;component/Resources/icons_general/general_trash-16.png" />
						</Button>
						<Button
							Grid.Row="2"
							Style="{DynamicResource ButtonWithIconOnly}"
							ToolTip="{tombLib:Localize EditFrameButton}">
							<Image Source="/TombEditor;component/Resources/icons_actions/actions_refresh-16.png" />
						</Button>
						<DockPanel
							Grid.Row="3"
							Width="25"
							VerticalAlignment="Stretch"
							Background="Firebrick"
							Visibility="Hidden">
							<Image Source="/TombEditor;component/Resources/icons_general/general_Warning-16.png" />
						</DockPanel>
						<Button
							Grid.Row="4"
							VerticalAlignment="Bottom"
							Style="{DynamicResource ButtonWithIconOnly}"
							ToolTip="{tombLib:Localize PrevFrame}">
							<Image Source="/TombEditor;component/Resources/icons_general/general_ArrowUp-16.png" />
						</Button>
						<Button Grid.Row="5" Style="{DynamicResource ButtonWithIconOnly}">
							<Image Source="/TombEditor;component/Resources/icons_general/general_ArrowDown-16.png" ToolTip="{tombLib:Localize NextFrame}" />
						</Button>
					</controls:SpacedGrid>
				</controls:SpacedGrid>
			</GroupBox>
		</controls:SpacedGrid>
		<controls:SpacedGrid Grid.Row="2" Grid.Column="0">
			<Grid.ColumnDefinitions>
				<ColumnDefinition />
				<ColumnDefinition Width="133" />
			</Grid.ColumnDefinitions>
			<StackPanel Grid.Row="0">
				<GroupBox Header="{tombLib:Localize ProcAnimTool}">
					<controls:SpacedGrid>
						<Grid.ColumnDefinitions>
							<ColumnDefinition Width="*" />
						</Grid.ColumnDefinitions>
						<controls:SpacedGrid.RowDefinitions>
							<RowDefinition Height="auto" />
							<RowDefinition Height="auto" />
							<RowDefinition Height="auto" />
						</controls:SpacedGrid.RowDefinitions>
						<controls:SpacedGrid Grid.Row="0">
							<Grid.ColumnDefinitions>
								<ColumnDefinition />
								<ColumnDefinition Width="auto" />
								<ColumnDefinition Width="Auto" />
							</Grid.ColumnDefinitions>
							<Label
								Grid.Column="0"
								HorizontalAlignment="Stretch"
								Content="{tombLib:Localize Animator}" />
							<Label
								Grid.Column="1"
								Width="63"
								Content="{tombLib:Localize ProgressPerc}" />
							<Label
								Grid.Column="2"
								Width="68"
								Content="{tombLib:Localize Frames}" />
						</controls:SpacedGrid>
						<controls:SpacedGrid Grid.Row="1">
							<Grid.ColumnDefinitions>
								<ColumnDefinition />
								<ColumnDefinition Width="auto" />
								<ColumnDefinition Width="Auto" />
							</Grid.ColumnDefinitions>
							<ComboBox
								Grid.Column="0"
								HorizontalAlignment="Stretch"
								ToolTip="Animation type">
								<ComboBoxItem Content="{tombLib:Localize StretchHorizontal}" />
								<ComboBoxItem Content="{tombLib:Localize StretchVertical}" />
								<ComboBoxItem Content="{tombLib:Localize Scale}" />
								<ComboBoxItem Content="{tombLib:Localize SkewHorizontalRL}" />
								<ComboBoxItem Content="{tombLib:Localize SkewHorizontalLR}" />
								<ComboBoxItem Content="{tombLib:Localize SkewVerticalRL}" />
								<ComboBoxItem Content="{tombLib:Localize SkewVerticalLR}" />
								<ComboBoxItem Content="{tombLib:Localize Spin}" />
								<ComboBoxItem Content="{tombLib:Localize PanHorizontal}" />
								<ComboBoxItem Content="{tombLib:Localize Frames}" />
								<ComboBoxItem Content="{tombLib:Localize Shake}" />
							</ComboBox>
							<xceed:IntegerUpDown
								Grid.Column="1"
								Width="64"
								ToolTip="Effect progress or strength" />
							<xceed:IntegerUpDown
								Grid.Column="2"
								Width="68"
								ToolTip="Amount of resulting animation frames" />
						</controls:SpacedGrid>
						<controls:SpacedGrid Grid.Row="2">
							<Grid.ColumnDefinitions>
								<ColumnDefinition Width="auto" />
								<ColumnDefinition />
								<ColumnDefinition Width="Auto" />
							</Grid.ColumnDefinitions>
							<CheckBox Grid.Column="0" Content="{tombLib:Localize Symmetric}" />
							<CheckBox
								Grid.Column="1"
								HorizontalAlignment="Stretch"
								Content="{tombLib:Localize Smooth}" />
							<controls:SpacedGrid Grid.Column="2">
								<Grid.ColumnDefinitions>
									<ColumnDefinition Width="auto" />
									<ColumnDefinition Width="auto" />
									<ColumnDefinition Width="Auto" />
									<ColumnDefinition Width="Auto" />
									<ColumnDefinition Width="Auto" />
								</Grid.ColumnDefinitions>
								<Button
									Grid.Column="0"
									Style="{DynamicResource ButtonWithIconOnly}"
									ToolTip="Generate new animation">
									<Image Source="/TombEditor;component/Resources/icons_general/general_create_new-16.png" />
								</Button>
								<Button
									Grid.Column="1"
									Style="{DynamicResource ButtonWithIconOnly}"
									ToolTip="Generate and merge into copy of current animation">
									<Image Source="/TombEditor;component/Resources/icons_general/general_copy-16.png" />
								</Button>
								<Button
									Grid.Column="2"
									Style="{DynamicResource ButtonWithIconOnly}"
									ToolTip="Generate and merge into current animation">
									<Image Source="/TombEditor;component/Resources/icons_actions/actions_Merge-16.png" />
								</Button>
								<Button
									Grid.Column="3"
									Style="{DynamicResource ButtonWithIconOnly}"
									ToolTip="Generate and add frames after current sequence frame">
									<Image Source="/TombEditor;component/Resources/icons_general/general_plus_math-16.png" />
								</Button>
								<Button
									Grid.Column="4"
									Style="{DynamicResource ButtonWithIconOnly}"
									ToolTip="Generate and replace current animation">
									<Image Source="/TombEditor;component/Resources/icons_actions/actions_refresh-16.png" />
								</Button>
							</controls:SpacedGrid>
						</controls:SpacedGrid>
					</controls:SpacedGrid>
				</GroupBox>
				<GroupBox Height="84" Header="{tombLib:Localize Setting}">
					<controls:SpacedGrid>
						<Grid.ColumnDefinitions>
							<ColumnDefinition />
							<ColumnDefinition Width="auto" />
							<ColumnDefinition Width="auto" />
						</Grid.ColumnDefinitions>
						<controls:SpacedGrid.RowDefinitions>
							<RowDefinition Height="auto" />
							<RowDefinition Height="auto" />
						</controls:SpacedGrid.RowDefinitions>
						<Label
							Grid.Row="0"
							Grid.Column="0"
							HorizontalAlignment="Stretch"
							Content="{tombLib:Localize Type}" />
						<Label
							Grid.Row="0"
							Grid.Column="1"
							Width="71"
							Content="FPS:" />
						<Label
							Grid.Row="0"
							Grid.Column="2"
							Content="UvRotate" />
						<ComboBox
							Grid.Row="1"
							Grid.Column="0"
							HorizontalAlignment="Stretch">
							<ComboBoxItem Content="{tombLib:Localize Frames}" />
							<ComboBoxItem Content="UVRotate" />
							<ComboBoxItem Content="PFrames" />
						</ComboBox>
						<xceed:IntegerUpDown
							Grid.Row="1"
							Grid.Column="1"
							Width="74"
							Visibility="Hidden" />
