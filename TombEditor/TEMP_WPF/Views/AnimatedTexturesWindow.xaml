				</GroupBox>
			</StackPanel>
			<StackPanel Grid.Column="1">
				<GroupBox Height="188" Header="{tombLib:Localize Preview}">
					<controls:SpacedGrid>
						<Grid.RowDefinitions>
							<RowDefinition Height="120" />
							<RowDefinition Height="auto" />
						</Grid.RowDefinitions>
						<Border
							Grid.Row="0"
							Width="113"
							Height="113"
							BorderBrush="#FF5C5C5C"
							BorderThickness="1">
							<Image
								Name="img1"
								Width="113"
								Height="113"
								Source="/TombEditor;component/Resources/misc/TE.png" />
						</Border>
						<ProgressBar Grid.Row="1" VerticalAlignment="Center" />
