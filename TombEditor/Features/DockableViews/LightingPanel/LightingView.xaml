<UserControl
	x:Class="TombEditor.Features.DockableViews.LightingPanel.LightingView"
	xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
	xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
	xmlns:controls="clr-namespace:DarkUI.WPF.CustomControls;assembly=DarkUI.WPF"
	xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
	xmlns:darkUI="clr-namespace:DarkUI.WPF;assembly=DarkUI.WPF"
	xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
	xmlns:tombLib="clr-namespace:TombLib.WPF;assembly=TombLib.WPF"
	d:DesignHeight="120"
	d:DesignWidth="375"
	Background="{DynamicResource Brush_Background}"
	RenderOptions.BitmapScalingMode="NearestNeighbor"
	mc:Ignorable="d">

	<controls:SpacedGrid Margin="{x:Static darkUI:Defaults.SmallThickness}" ColumnSpacing="{x:Static darkUI:Defaults.SmallThicknessWidth}">
		<Grid.ColumnDefinitions>
			<ColumnDefinition Width="Auto" />
			<ColumnDefinition />
		</Grid.ColumnDefinitions>

		<controls:SpacedGrid RowSpacing="{x:Static darkUI:Defaults.SmallThicknessWidth}">
			<Grid.RowDefinitions>
				<RowDefinition Height="Auto" />
				<RowDefinition />
			</Grid.RowDefinitions>

			<controls:SpacedGrid RowSpacing="{x:Static darkUI:Defaults.SmallThicknessWidth}">
				<Grid.RowDefinitions>
					<RowDefinition Height="Auto" />
					<RowDefinition Height="Auto" />
				</Grid.RowDefinitions>

				<controls:SpacedGrid ColumnSpacing="{x:Static darkUI:Defaults.SmallThicknessWidth}">
					<Grid.ColumnDefinitions>
						<ColumnDefinition />
						<ColumnDefinition Width="Auto" />
					</Grid.ColumnDefinitions>

					<ComboBox SelectedIndex="{Binding SelectedLightType}">
						<ComboBoxItem Style="{DynamicResource ComboBoxItemWithIconAndText}">
							<StackPanel Orientation="Horizontal">
								<Image Source="/TombEditor;component/Resources/icons_objects/objects_LightPoint-16.png" />
								<TextBlock Text="{tombLib:Localize TypePoint}" />
							</StackPanel>
						</ComboBoxItem>

						<ComboBoxItem Style="{DynamicResource ComboBoxItemWithIconAndText}">
							<StackPanel Orientation="Horizontal">
								<Image Source="/TombEditor;component/Resources/icons_objects/objects_Shadow-16.png" />
								<TextBlock Text="{tombLib:Localize TypeShadow}" />
							</StackPanel>
						</ComboBoxItem>

						<ComboBoxItem Style="{DynamicResource ComboBoxItemWithIconAndText}">
							<StackPanel Orientation="Horizontal">
								<Image Source="/TombEditor;component/Resources/icons_objects/objects_Spotlight-16.png" />
								<TextBlock Text="{tombLib:Localize TypeSpot}" />
							</StackPanel>
						</ComboBoxItem>

						<ComboBoxItem Style="{DynamicResource ComboBoxItemWithIconAndText}">
							<StackPanel Orientation="Horizontal">
								<Image Source="/TombEditor;component/Resources/icons_objects/objects_Effect-16.png" />
								<TextBlock Text="{tombLib:Localize TypeEffect}" />
							</StackPanel>
						</ComboBoxItem>

						<ComboBoxItem Style="{DynamicResource ComboBoxItemWithIconAndText}">
							<StackPanel Orientation="Horizontal">
								<Image Source="/TombEditor;component/Resources/icons_objects/objects_sun-16.png" />
								<TextBlock Text="{tombLib:Localize TypeSun}" />
							</StackPanel>
						</ComboBoxItem>

						<ComboBoxItem Style="{DynamicResource ComboBoxItemWithIconAndText}">
							<StackPanel Orientation="Horizontal">
								<Image Source="/TombEditor;component/Resources/icons_objects/objects_Fog-16.png" />
								<TextBlock Text="{tombLib:Localize TypeFogBulb}" />
							</StackPanel>
						</ComboBoxItem>
					</ComboBox>

					<Button
						Grid.Column="1"
						Command="{Binding AddLightCommand}"
						Style="{DynamicResource ButtonWithIconOnly}">
						<Image Source="/TombEditor;component/Resources/icons_general/general_plus_math-16.png" />
					</Button>
				</controls:SpacedGrid>

				<ComboBox
					Grid.Row="1"
					Grid.ColumnSpan="2"
					IsEnabled="{Binding CanEditQuality}"
					SelectedIndex="{Binding SelectedLightQuality}">
					<ComboBoxItem Content="{tombLib:Localize QualityDefault}" />
					<ComboBoxItem Content="{tombLib:Localize QualityLow}" />
					<ComboBoxItem Content="{tombLib:Localize QualityMedium}" />
					<ComboBoxItem Content="{tombLib:Localize QualityHigh}" />
				</ComboBox>
			</controls:SpacedGrid>

			<controls:SpacedGrid
				Grid.Row="1"
				ColumnSpacing="{x:Static darkUI:Defaults.LargeThicknessWidth}"
				RowSpacing="{x:Static darkUI:Defaults.SmallThicknessWidth}">
				<Grid.ColumnDefinitions>
					<ColumnDefinition />
					<ColumnDefinition />
				</Grid.ColumnDefinitions>

				<Grid.RowDefinitions>
					<RowDefinition Height="Auto" />
					<RowDefinition Height="Auto" />
					<RowDefinition Height="Auto" />
					<RowDefinition />
				</Grid.RowDefinitions>

				<CheckBox
					Content="{tombLib:Localize Enabled}"
					IsChecked="{Binding LightEnabled}"
					IsEnabled="{Binding HasLight}" />
				<CheckBox
					Grid.Row="1"
					Content="{tombLib:Localize Obstruct}"
					IsChecked="{Binding ObstructedByGeometry}"
					IsEnabled="{Binding CanCastShadows}" />
				<CheckBox
					Grid.Row="2"
					Content="{tombLib:Localize Shadow}"
					IsChecked="{Binding CastsShadow}"
					IsEnabled="{Binding CanCastDynamicShadows}" />

				<CheckBox
					Grid.Column="1"
					Content="{tombLib:Localize Static}"
					IsChecked="{Binding StaticallyUsed}"
					IsEnabled="{Binding CanIlluminateGeometry}" />
				<CheckBox
					Grid.Row="1"
					Grid.Column="1"
					Content="{tombLib:Localize Dynamic}"
					IsChecked="{Binding DynamicallyUsed}"
					IsEnabled="{Binding CanIlluminateGeometry}" />
				<CheckBox
					Grid.Row="2"
					Grid.Column="1"
					Content="{tombLib:Localize Imported}"
					IsChecked="{Binding UsedForImportedGeometry}"
					IsEnabled="{Binding CanIlluminateGeometry}" />
			</controls:SpacedGrid>
		</controls:SpacedGrid>

		<controls:SpacedGrid Grid.Column="1" RowSpacing="{x:Static darkUI:Defaults.SmallThicknessWidth}">
			<Grid.ColumnDefinitions>
				<ColumnDefinition Width="Auto" />
				<ColumnDefinition />
				<ColumnDefinition Width="Auto" />
				<ColumnDefinition />
			</Grid.ColumnDefinitions>

			<Grid.RowDefinitions>
				<RowDefinition Height="Auto" />
				<RowDefinition Height="Auto" />
				<RowDefinition Height="Auto" />
				<RowDefinition Height="Auto" />
				<RowDefinition />
			</Grid.RowDefinitions>

			<Label
				HorizontalAlignment="Right"
				Content="{tombLib:Localize Color}"
				Style="{DynamicResource ExtraHorizontalMarginLabel}" />
			<controls:ColorPickerButton
				Grid.Column="1"
				Height="22"
				Command="{Binding EditLightColorCommand}"
				IsEnabled="{Binding HasLight}"
				SelectedColor="{Binding LightColor, Mode=OneWay}" />
			<Label
				Grid.Row="1"
				HorizontalAlignment="Right"
				Content="{tombLib:Localize Intensity}"
				Style="{DynamicResource ExtraHorizontalMarginLabel}" />
			<controls:NumericUpDown
				Grid.Row="1"
				Grid.Column="1"
				FormatString="F2"
				Increment="0.01"
				IsEnabled="{Binding HasLight}"
				Value="{Binding Intensity}" />
			<Label
				Grid.Row="2"
				HorizontalAlignment="Right"
				Content="{tombLib:Localize InnerDistance}"
				Style="{DynamicResource ExtraHorizontalMarginLabel}" />
			<controls:NumericUpDown
				Grid.Row="2"
				Grid.Column="1"
				FormatString="F2"
				Increment="0.01"
				IsEnabled="{Binding CanEditInRange}"
				Value="{Binding InnerRange}" />
			<Label
				Grid.Row="3"
				HorizontalAlignment="Right"
				Content="{tombLib:Localize OuterDistance}"
				Style="{DynamicResource ExtraHorizontalMarginLabel}" />
			<controls:NumericUpDown
				Grid.Row="3"
				Grid.Column="1"
				FormatString="F2"
				Increment="0.01"
				IsEnabled="{Binding CanEditOutRange}"
				Value="{Binding OuterRange}" />

			<Label
				Grid.Column="2"
				HorizontalAlignment="Right"
				Content="{tombLib:Localize InnerAngle}"
				Style="{DynamicResource ExtraHorizontalMarginLabel}">
				<Label.Margin>
					<Thickness Left="{x:Static darkUI:Defaults.SmallThicknessWidth}" />
				</Label.Margin>
			</Label>
			<controls:NumericUpDown
				Grid.Column="3"
				FormatString="F2"
				Increment="0.01"
				IsEnabled="{Binding CanEditInOutAngle}"
				Value="{Binding InnerAngle}" />
			<Label
				Grid.Row="1"
				Grid.Column="2"
				HorizontalAlignment="Right"
				Content="{tombLib:Localize OuterAngle}"
				Style="{DynamicResource ExtraHorizontalMarginLabel}">
				<Label.Margin>
					<Thickness Left="{x:Static darkUI:Defaults.SmallThicknessWidth}" />
				</Label.Margin>
			</Label>
			<controls:NumericUpDown
				Grid.Row="1"
				Grid.Column="3"
				FormatString="F2"
				Increment="0.01"
				IsEnabled="{Binding CanEditInOutAngle}"
				Value="{Binding OuterAngle}" />
			<Label
				Grid.Row="2"
				Grid.Column="2"
				HorizontalAlignment="Right"
				Content="{tombLib:Localize DirectionY}"
				Style="{DynamicResource ExtraHorizontalMarginLabel}">
				<Label.Margin>
					<Thickness Left="{x:Static darkUI:Defaults.SmallThicknessWidth}" />
				</Label.Margin>
			</Label>
			<controls:NumericUpDown
				Grid.Row="2"
				Grid.Column="3"
				FormatString="F2"
				Increment="0.01"
				IsEnabled="{Binding CanEditDirection}"
				Value="{Binding DirectionY}" />
			<Label
				Grid.Row="3"
				Grid.Column="2"
				HorizontalAlignment="Right"
				Content="{tombLib:Localize DirectionX}"
				Style="{DynamicResource ExtraHorizontalMarginLabel}">
				<Label.Margin>
					<Thickness Left="{x:Static darkUI:Defaults.SmallThicknessWidth}" />
				</Label.Margin>
			</Label>
			<controls:NumericUpDown
				Grid.Row="3"
				Grid.Column="3"
				FormatString="F2"
				Increment="0.01"
				IsEnabled="{Binding CanEditDirection}"
				Value="{Binding DirectionX}" />
		</controls:SpacedGrid>
	</controls:SpacedGrid>
</UserControl>
